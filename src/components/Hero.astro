</style>

<script>
  // Confetti Particle System
  class ConfettiParticle {
    x: number;
    y: number;
    size: number;
    color: string;
    vx: number;
    vy: number;
    rotation: number;
    rotationSpeed: number;
    opacity: number;
    decay: number;
    width: number;
    height: number;
    shape: "circle" | "square" | "triangle";

    constructor(x: number, y: number, isCannon = false) {
      this.x = x;
      this.y = y;
      this.size = Math.random() * 8 + 6;

      const colors = [
        "#10b981",
        "#f59e0b",
        "#ec4899",
        "#3b82f6",
        "#8b5cf6",
        "#84cc16",
      ];
      this.color = colors[Math.floor(Math.random() * colors.length)];

      if (isCannon) {
        this.vx = 0;
        this.vy = 0;
      } else {
        const angle = Math.random() * Math.PI * 2;
        const speed = Math.random() * 6 + 2;
        this.vx = Math.cos(angle) * speed;
        this.vy = Math.sin(angle) * speed - 2;
      }

      this.rotation = Math.random() * 360;
      this.rotationSpeed = (Math.random() - 0.5) * 8;
      this.opacity = 1;
      this.decay = Math.random() * 0.01 + 0.008;

      this.width = this.size;
      this.height = this.size * (Math.random() * 0.5 + 0.5);

      const shapes: ("circle" | "square" | "triangle")[] = [
        "circle",
        "square",
        "triangle",
      ];
      this.shape = shapes[Math.floor(Math.random() * shapes.length)];
    }

    update() {
      this.x += this.vx;
      this.y += this.vy;
      this.vy += 0.15; // gravity
      this.vx *= 0.98; // air resistance
      this.vy *= 0.98;
      this.rotation += this.rotationSpeed;
      this.opacity -= this.decay;
    }

    draw(ctx: CanvasRenderingContext2D) {
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate((this.rotation * Math.PI) / 180);
      ctx.globalAlpha = this.opacity;
      ctx.fillStyle = this.color;

      const w = this.width * Math.abs(Math.sin(this.rotation * 0.05));
      const h = this.height;

      ctx.beginPath();
      if (this.shape === "circle") {
        ctx.arc(0, 0, w / 2, 0, Math.PI * 2);
      } else if (this.shape === "triangle") {
        ctx.moveTo(0, -h / 2);
        ctx.lineTo(w / 2, h / 2);
        ctx.lineTo(-w / 2, h / 2);
        ctx.closePath();
      } else {
        ctx.rect(-w / 2, -h / 2, w, h);
      }
      ctx.fill();
      ctx.restore();
    }
  }

  let particles: ConfettiParticle[] = [];
  let animationId: number | null = null;
  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;

  function initCanvas() {
    canvas = document.getElementById("confetti-canvas") as HTMLCanvasElement;
    if (!canvas) {
      canvas = document.createElement("canvas");
      canvas.id = "confetti-canvas";
      canvas.style.position = "absolute";
      canvas.style.top = "0";
      canvas.style.left = "0";
      canvas.style.width = "100%";
      canvas.style.height = "100%";
      canvas.style.pointerEvents = "none";
      canvas.style.zIndex = "99";
      const hero = document.getElementById("hero-section");
      if (hero) {
        hero.appendChild(canvas);
      }
    }
    ctx = canvas.getContext("2d");
    resizeCanvas();
    window.addEventListener("resize", resizeCanvas);
  }

  function resizeCanvas() {
    if (canvas) {
      canvas.width = canvas.parentElement?.clientWidth || window.innerWidth;
      canvas.height = canvas.parentElement?.clientHeight || window.innerHeight;
    }
  }

  function animate() {
    if (!ctx || !canvas) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.update();
      p.draw(ctx);
      if (p.opacity <= 0) {
        particles.splice(i, 1);
      }
    }

    if (particles.length > 0) {
      animationId = requestAnimationFrame(animate);
    } else {
      animationId = null;
    }
  }

  function fireConfetti(clientX?: number, clientY?: number) {
    if (!canvas) {
      initCanvas();
    }
    if (!canvas) return;

    const width = canvas.width;
    const height = canvas.height;

    // Local click burst
    if (clientX !== undefined && clientY !== undefined) {
      const rect = canvas.getBoundingClientRect();
      const x = clientX - rect.left;
      const y = clientY - rect.top;
      for (let i = 0; i < 45; i++) {
        particles.push(new ConfettiParticle(x, y));
      }
    } else {
      for (let i = 0; i < 45; i++) {
        particles.push(new ConfettiParticle(width / 2, height / 2));
      }
    }

    // Left cannon
    for (let i = 0; i < 40; i++) {
      const p = new ConfettiParticle(0, height, true);
      const angle = -Math.random() * 40 - 20;
      const rad = (angle * Math.PI) / 180;
      const speed = Math.random() * 12 + 8;
      p.vx = Math.cos(rad) * speed;
      p.vy = Math.sin(rad) * speed;
      particles.push(p);
    }

    // Right cannon
    for (let i = 0; i < 40; i++) {
      const p = new ConfettiParticle(width, height, true);
      const angle = -Math.random() * 40 - 100;
      const rad = (angle * Math.PI) / 180;
      const speed = Math.random() * 12 + 8;
      p.vx = Math.cos(rad) * speed;
      p.vy = Math.sin(rad) * speed;
      particles.push(p);
    }

    if (!animationId) {
      animate();
    }
  }

  const copyBtn = document.getElementById("copy-e");
  const heroSection = document.getElementById("hero-section");
  const marqueeContainer = document.getElementById("marquee-container");

  const performCopy = async () => {
    const textToCopy = copyBtn?.getAttribute("data-char") || "È";
    try {
      await navigator.clipboard.writeText(textToCopy);
    } catch (err) {
      console.error("Errore durante la copia negli appunti: ", err);
    }
  };

  let successTimeoutId: number | null = null;
  const triggerSuccess = (e: MouseEvent) => {
    if (heroSection) {
      heroSection.classList.add("copied-success");
      if (successTimeoutId) {
        clearTimeout(successTimeoutId);
      }
      successTimeoutId = window.setTimeout(() => {
        heroSection.classList.remove("copied-success");
        successTimeoutId = null;
      }, 2000);
    }
    fireConfetti(e.clientX, e.clientY);
  };

  if (copyBtn && heroSection) {
    copyBtn.addEventListener("click", async (e) => {
      await performCopy();
      heroSection.classList.add("show-marquee");
      triggerSuccess(e);
    });
  }

  if (marqueeContainer && heroSection) {
    marqueeContainer.addEventListener("click", async (e) => {
      await performCopy();
      heroSection.classList.add("show-marquee");
      triggerSuccess(e);
    });
  }

  const plusPanel = document.getElementById("plus-panel");
  const panelToggleBtn = document.getElementById("panel-toggle-btn");
  const plusBtn = document.getElementById("plus-btn");
  const panelCopyBox = document.getElementById("panel-copy-box");

  if (panelCopyBox) {
    panelCopyBox.addEventListener("click", async (e) => {
      e.stopPropagation();
      const textToCopy = panelCopyBox.getAttribute("data-char") || "È";
      try {
        await navigator.clipboard.writeText(textToCopy);
        const label = panelCopyBox.querySelector(".panel-copy-label");
        if (label) {
          const originalText = label.textContent;
          label.textContent = "Copiato!";
          (label as HTMLElement).style.color = "#00aa00";
          setTimeout(() => {
            label.textContent = originalText;
            (label as HTMLElement).style.color = "";
          }, 1500);
        }
        fireConfetti(e.clientX, e.clientY);
      } catch (err) {
        console.error("Errore durante la copia negli appunti: ", err);
      }
    });
  }

  let isHoverDisabled = false;

  if (plusPanel) {
    plusPanel.addEventListener("mouseenter", () => {
      if (!isHoverDisabled) {
        plusPanel.classList.add("is-expanded");
      }
    });

    plusPanel.addEventListener("mouseleave", () => {
      plusPanel.classList.remove("is-expanded");
      isHoverDisabled = false;
    });
  }

  if (panelToggleBtn && plusPanel) {
    panelToggleBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (plusPanel.classList.contains("is-expanded")) {
        plusPanel.classList.remove("is-expanded");
        isHoverDisabled = true;
      } else {
        plusPanel.classList.add("is-expanded");
      }
    });
  }

  if (plusBtn && plusPanel) {
    plusBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      plusPanel.classList.add("is-expanded");
    });
  }

  const creditsWrap = document.getElementById("credits-wrap");
  const creditsTrig = document.getElementById("credits-trig");

  if (creditsTrig && creditsWrap) {
    creditsTrig.addEventListener("click", (e) => {
      e.stopPropagation();
      creditsWrap.classList.toggle("is-open");
      creditsTrig.classList.toggle("is-active");
    });
  }

  document.addEventListener("click", (e) => {
    if (
      plusPanel &&
      plusPanel.classList.contains("is-expanded") &&
      !plusPanel.contains(e.target as Node)
    ) {
      plusPanel.classList.remove("is-expanded");
    }
    if (creditsWrap && !creditsWrap.contains(e.target as Node)) {
      creditsWrap.classList.remove("is-open");
      if (creditsTrig) {
        creditsTrig.classList.remove("is-active");
      }
    }
  });
</script>
