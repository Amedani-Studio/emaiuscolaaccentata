---
import "../styles/global.scss";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "E maiuscola accentata - copia facilmente",
  description = "Strumento gratuito per copiare la E maiuscola accentata (È). Scopri come digitare È facilmente. Perfetto per documenti e scritti formali.",
} = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="e maiuscola accentata, È, come digitare è, copia è accentata, scorciatoie tastiera"
    />
    <meta name="author" content="Amedani Studio" />
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <link
      rel="canonical"
      href={`https://emaiuscolaaccentata.org${Astro.url.pathname}`}
    />

    <!-- Open Graph / Social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={`https://emaiuscolaaccentata.org${Astro.url.pathname}`}
    />
    <meta property="og:image" content="https://emaiuscolaaccentata.org/og-image.png" />
    <meta property="og:locale" content="it_IT" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://emaiuscolaaccentata.org/og-image.png" />

    <!-- Preconnect Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "È Maiuscola Accentata",
        "description": "Strumento per copiare la E maiuscola accentata facilmente",
        "url": "https://emaiuscolaaccentata.org",
        "applicationCategory": "UtilityApplication",
        "operatingSystem": "Web",
        "creator": {
          "@type": "Organization",
          "name": "Amedani Studio",
          "url": "https://amedanistudio.pages.dev"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "EUR"
        }
      }
    </script>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Come si fa la È maiuscola accentata sulla tastiera?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Su Windows, puoi fare la È maiuscola accentata tenendo premuto il tasto Alt e digitando 212 sul tastierino numerico. Su Mac, puoi premere Option + E, poi rilasciare e premere Shift + E. In alternativa, puoi copiare il carattere È con un solo clic su questo sito."
            }
          },
          {
            "@type": "Question",
            "name": "Qual è il codice ASCII per la È maiuscola accentata?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Il codice ASCII per la È maiuscola accentata è 212. Si digita tenendo premuto il tasto Alt ed inserendo la sequenza numerica 212 sul tastierino numerico."
            }
          },
          {
            "@type": "Question",
            "name": "Come fare la È maiuscola accentata senza tastierino numerico?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Se non disponi di un tastierino numerico su Windows, puoi copiare la È direttamente con un clic su questo sito, oppure cercare la Mappa Caratteri integrata di Windows, selezionare la È maiuscola e cliccare su copia."
            }
          }
        ]
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
